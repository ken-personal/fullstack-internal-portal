generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm, vector]
}

enum Role {
  ADMIN
  MANAGER
  USER
}

model User {
  id        Int      @id @default(autoincrement())
  title     String
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
}

model Sale {
  id         Int      @id @default(autoincrement())
  title      String
  amount     Float
  user       String
  department String
  date       DateTime
  createdAt  DateTime @default(now())
}

model Expense {
  id         Int      @id @default(autoincrement())
  title      String
  amount     Float
  user       String
  department String
  date       DateTime
  createdAt  DateTime @default(now())
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  author    String
  date      DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Inquiry {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  createdAt DateTime @default(now())
}

model Document {
  id         Int      @id @default(autoincrement())
  fileName   String
  fileKey    String
  fileSize   Int
  mimeType   String
  uploadedBy String
  createdAt  DateTime @default(now())
}

/// RAG 用ベクトル埋め込みテーブル（Gemini text-embedding-004: 768 次元）
model DocumentEmbedding {
  id         Int      @id @default(autoincrement())
  sourceType String   // "announcement" | "user" | "inquiry"
  sourceId   Int
  content    String   // 埋め込んだテキスト本文
  embedding  Unsupported("vector(768)")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([sourceType, sourceId])
}